# =====================================================================
# BNI Finance System — Environment Variables
# Copy to .env.local and fill in. The UI runs on mock data by default;
# set VITE_USE_MOCK=false once the real backend endpoints are wired up.
# =====================================================================

# Toggle the data source. "true" = in-memory mock repositories (default).
VITE_USE_MOCK=true

# --- Supabase (project terpisah untuk data finansial) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- BNI Visitor Management API (sumber sync member & chapter) ---
VITE_BNI_VM_URL=https://www.bni-vh.com/api/external/v1
VITE_BNI_VM_TOKEN=

# --- Paper.id (integrasi invoice & pembayaran) ---
VITE_PAPER_ID_API_URL=https://api.paper.id/v1
